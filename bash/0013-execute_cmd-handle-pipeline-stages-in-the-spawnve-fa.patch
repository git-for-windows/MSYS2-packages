From 05b8f5e3eeb9985615b2b274adfa465685b44d14 Mon Sep 17 00:00:00 2001
From: Johannes Schindelin <johannes.schindelin@gmx.de>
Date: Wed, 6 May 2026 18:06:56 +0200
Subject: [PATCH 13/25] execute_cmd: handle pipeline stages in the spawnve fast
 path

Extend fast_spawn_command to accept pipe_in / pipe_out / fds_to_close,
which previously caused an unconditional bail-out.  The fork path
applies these in the post-fork child via do_piping() and
close_fd_bitmap(); we have no such hook, so we emulate the same effect
in the parent before spawnve and reverse it afterwards:

  - if pipe_in != NO_PIPE, dup() fd 0 into a CLOEXEC save fd and
    dup2(pipe_in, 0).  The CLOEXEC keeps the save fd from leaking to
    the spawnve child.
  - if pipe_out != NO_PIPE, do the same for fd 1.  pipe_out ==
    REDIRECT_BOTH (the `|&' merge) is bailed out for now; it would
    require interleaving dup2(1, 2) with the rest of the pipe setup.
  - for each fd marked in fds_to_close (extra pipe ends from
    neighboring pipeline stages that the child must not see), save
    the current FD_CLOEXEC bits and force them on so spawnve does not
    inherit those fds.  After spawnve, restore the original flags.

After spawnve, the order of restoration is the reverse of setup:
fds_to_close FD_CLOEXEC restored, then fd 1, then fd 0.  A
pipe_setup_fail label provides one place to undo all partial setup
on any error path (dup/dup2/redirection failure).

Microbenchmark results (200 iterations, warm averages, vs the
distro bash):

  workload                          distro    patched
  ----------------------------------- -------  --------
  /usr/bin/true                       7.7s     4.0s    (1.93x)
  /usr/bin/true >/dev/null 2>&1       7.7s     4.0s    (1.93x)
  /usr/bin/true | /usr/bin/cat       13.7s    15.2s    (0.90x)
  t1022-read-tree-partial-clone.sh    4.9s     2.4s    (2.05x)

The 2-stage-pipeline microbench is at distro parity but slightly
slower (~10%); each pipeline stage now does extra parent-side
fd surgery (dup, fcntl, dup2 setup and restore) that the fork path
got for free in the post-fork child.  Real Git tests like t1022
still see a 2.05x speedup overall because they are dominated by
plain externals and redirected externals where the fast path's
spawnve-vs-fork advantage is large.

This change also tightens the redirection filter to bail out on
filename redirections containing command substitution (`$(cmd)` or
backticks), addressing a hazard the rubber-duck pass surfaced: the
existing redirect support called do_redirections in the parent,
which means redirection_expand runs in the parent.  Process
substitution was already filtered, but command substitution was
not.  A redirect like `>"$(VAR=foo cmd)"` would have run the
substitution in the parent shell, leaking variable assignments and
trap effects that the fork path would have isolated to the child.
The filter now also rejects backticks for the same reason.  Plain
parameter expansion (`>"$VAR"`, `>"${VAR}"`) and tilde expansion
remain accepted; they are pure reads of shell state.

The rubber-duck pass surfaced five potential blockers; empirical
testing on Cygwin spawnve disposed of three of them and the
remaining two are addressed:

  1. Signal mask leakage to child.  Tested empirically with a
     helper that prints sigprocmask: spawnve children start with
     SIGCHLD/SIGINT/SIGTERM all unblocked regardless of the parent's
     mask at spawn time.  Cygwin's spawnve resets the child mask
     internally.  No change needed.
  2. fds_to_close ordering vs pipe dup2.  The hypothetical hazard
     was that if pipe_out lands on an fd that was in fds_to_close,
     applying CLOEXEC after dup2 would leave the child's stdout
     CLOEXEC.  Empirically the dup2-to-fd-0/1 path clears the
     target's CLOEXEC bit (on Cygwin's dup2 implementation), and a
     closed-stdout pipeline test passes byte-identically against
     the original bash.  No change needed.
  3. pipe_in/pipe_out source-fd leak into child.  Tested by running
     a pipeline stage that lists /proc/self/fd; output is identical
     to the original bash.  Cygwin's spawnve appears to honor
     CLOEXEC consistently for fds beyond the pipe redirect.  No
     change needed.
  4. setpgid race vs job_control.  Real but only matters in
     interactive job-control mode; bash -c (the test-suite path)
     has job_control off.  Documented as future work.
  5. Command-substitution in filename redirections running in
     parent.  Addressed by extending fast_spawn_redirect_one_supported
     to bail out for `$(' and backticks.

Open future work tracked in this and the previous commits:

  - unwind-protect frames around the fd-surgery window so a
    trap/interrupt cannot leave the parent corrupted;
  - lift the fd >= 3 redirect restriction by walking new_undo_list
    and forcing FD_CLOEXEC on each save fd before spawnve;
  - heredoc support;
  - REDIRECT_BOTH (`cmd |& next') support;
  - sentinel return value to distinguish "fast path declined" from
    "redirection genuinely failed", avoiding double error reporting
    on the failure fallback;
  - replace dup+fcntl(F_SETFD,FD_CLOEXEC) pairs with single
    fcntl(F_DUPFD_CLOEXEC) calls when measurement shows that helps;
  - posix_spawn with file actions/sigmask attributes when Cygwin's
    implementation matures, replacing the manual fd surgery here.

Assisted-by: Claude Opus 4.7
Signed-off-by: Johannes Schindelin <johannes.schindelin@gmx.de>
---
 execute_cmd.c | 170 +++++++++++++++++++++++++++++++++++++++++---------
 1 file changed, 140 insertions(+), 30 deletions(-)

diff --git a/execute_cmd.c b/execute_cmd.c
index 3d7e417..b73a890 100644
--- a/execute_cmd.c
+++ b/execute_cmd.c
@@ -6006,16 +6006,23 @@ fast_spawn_redirect_one_supported (REDIRECT *r)
     case r_output_force:		/* >|file (noclobber bypass) */
     case r_err_and_out:			/* &>file */
     case r_append_err_and_out:		/* &>>file */
-      /* Filename redirections.  Detect process substitution (`<(cmd)`,
-	 `>(cmd)`) and bail; redirection_expand() would spawn the
-	 substitution children as children of the main shell rather than
-	 of the (would-be) forked external command, with substantial
-	 follow-on bookkeeping. */
-      if (r->redirectee.filename
-	  && r->redirectee.filename->word
-	  && (strncmp (r->redirectee.filename->word, "<(", 2) == 0
-	      || strncmp (r->redirectee.filename->word, ">(", 2) == 0))
-	return 0;
+      /* Filename redirections.  redirection_expand performs full word
+	 expansion (parameter, command, process substitution).  Process
+	 substitution and command substitution would run in our parent
+	 shell rather than in the (would-be) forked external command,
+	 turning child-side effects into parent-side effects.  Detect
+	 the common dangerous prefixes by literal scan.  Plain
+	 parameter expansion (`>$VAR`, `>"${VAR}"`) and tilde expansion
+	 are fine because they are pure, side-effect-free reads of
+	 shell state. */
+      if (r->redirectee.filename && r->redirectee.filename->word)
+	{
+	  const char *w = r->redirectee.filename->word;
+	  if (strncmp (w, "<(", 2) == 0 || strncmp (w, ">(", 2) == 0)
+	    return 0;	/* process substitution */
+	  if (strstr (w, "$(") != NULL || strchr (w, '`') != NULL)
+	    return 0;	/* command substitution */
+	}
       return 1;
 
     case r_duplicating_input:		/* <&N (constant fd) */
@@ -6057,7 +6064,7 @@ fast_spawn_redirect_supported (REDIRECT *list)
    On success returns the pid of the new child, which has been registered
    in the job table so that the caller's normal wait_for(last_made_pid)
    path will reap it.  Returns -1 if the command cannot be handled by the
-   fast path (pipes, async, CMD_NO_FORK, fds_to_close, or redirections
+   fast path (async, CMD_NO_FORK, REDIRECT_BOTH pipelines, or redirections
    that fail the safety checks above), in which case the caller must
    fall back to make_child().
 
@@ -6067,7 +6074,16 @@ fast_spawn_redirect_supported (REDIRECT *list)
    to restore the parent's fd table.  Both redirection_undo_list and
    exec_redirection_undo_list are protocol-managed: they are saved on
    entry, set to NULL across do_redirections (so the caller's existing
-   pending undos are not disposed), captured on success, and restored. */
+   pending undos are not disposed), captured on success, and restored.
+
+   For pipeline stages, pipe_in and pipe_out are dup'd into fd 0 / fd 1
+   in the parent (saving the originals so we can restore them) and the
+   fds_to_close bitmap (extra pipe ends from neighboring stages) is
+   given FD_CLOEXEC so spawnve's child does not inherit those fds.  The
+   regular fork path achieves the same effect in the post-fork child
+   via do_piping() and close_fd_bitmap(); we have to do it here in the
+   parent because spawnve does not give us a "between fork and exec"
+   hook to run code in the child. */
 static pid_t
 fast_spawn_command (char *command, WORD_LIST *words,
 		    REDIRECT *redirects, char *command_line,
@@ -6083,27 +6099,24 @@ fast_spawn_command (char *command, WORD_LIST *words,
   REDIRECT *new_undo_list = NULL;
   REDIRECT *new_exec_undo_list = NULL;
   int redirected = 0;
+  int saved_fd0 = -1, saved_fd1 = -1;
+  int *saved_cloexec = NULL;
+  int i;
 
   /* Conditions we don't yet handle.  Bail out and let make_child do it. */
-  if (pipe_in != NO_PIPE || pipe_out != NO_PIPE)
-    return (pid_t)-1;
   if (async)
     return (pid_t)-1;
   if (cmdflags & CMD_NO_FORK)
     return (pid_t)-1;
+  if (pipe_out == REDIRECT_BOTH)
+    /* `cmd |& next' merges stderr into the pipe.  do_piping handles
+       this by dup2(1, 2) AFTER the rest of the pipe redirection has
+       happened; we'd need to interleave that into our pipe setup
+       below.  Defer to a follow-up.  */
+    return (pid_t)-1;
   if (redirects && !fast_spawn_redirect_supported (redirects))
     return (pid_t)-1;
 
-  /* If there are inherited pipe fds that the child must not see,
-     fall back; the regular path closes them in the child after fork. */
-  if (fds_to_close)
-    {
-      int i;
-      for (i = 0; i < fds_to_close->size; i++)
-	if (fds_to_close->bitmap[i])
-	  return (pid_t)-1;
-    }
-
   /* Mirror make_child's signal blocking around the spawn so that SIGCHLD
      for the new child is held until we have registered it in the job
      table.  Otherwise waitchld() could fire before add_process().  We
@@ -6116,8 +6129,53 @@ fast_spawn_command (char *command, WORD_LIST *words,
   sigemptyset (&oset);
   sigprocmask (SIG_BLOCK, &set, &oset);
 
-  /* Apply redirections in the parent.  The regular path does this in
-     the post-fork child where the fork has given it a private fd table;
+  /* Set up pipe_in -> fd 0 and pipe_out -> fd 1 in the parent.  We
+     keep the originals as save fds (with FD_CLOEXEC so spawnve does
+     not leak them to the child) for restoration after spawnve.  The
+     pipeline coordinator in execute_pipeline owns pipe_in / pipe_out
+     and will close them once we return; we do not close them here. */
+  if (pipe_in != NO_PIPE)
+    {
+      saved_fd0 = dup (0);
+      if (saved_fd0 < 0
+	  || fcntl (saved_fd0, F_SETFD, FD_CLOEXEC) < 0
+	  || dup2 (pipe_in, 0) < 0)
+	goto pipe_setup_fail;
+    }
+  if (pipe_out != NO_PIPE)
+    {
+      saved_fd1 = dup (1);
+      if (saved_fd1 < 0
+	  || fcntl (saved_fd1, F_SETFD, FD_CLOEXEC) < 0
+	  || dup2 (pipe_out, 1) < 0)
+	goto pipe_setup_fail;
+    }
+
+  /* fds_to_close holds pipe ends inherited from neighboring pipeline
+     stages that the child must not see.  In the regular path the
+     post-fork child closes them via close_fd_bitmap(); spawnve gives
+     us no such hook, so we set FD_CLOEXEC on each listed fd before
+     the spawn and restore the previous flag bits after. */
+  if (fds_to_close && fds_to_close->size > 0)
+    {
+      saved_cloexec = (int *)xmalloc (fds_to_close->size * sizeof (int));
+      for (i = 0; i < fds_to_close->size; i++)
+	{
+	  saved_cloexec[i] = -1;
+	  if (fds_to_close->bitmap[i])
+	    {
+	      int flags = fcntl (i, F_GETFD);
+	      if (flags >= 0)
+		{
+		  saved_cloexec[i] = flags;
+		  fcntl (i, F_SETFD, flags | FD_CLOEXEC);
+		}
+	    }
+	}
+    }
+
+  /* Apply user redirections.  The regular path does this in the
+     post-fork child where the fork has given it a private fd table;
      we don't have that luxury, so we ask do_redirections for the undo
      ops and replay them after spawnve to restore our fds.  We swap
      both redirection_undo_list and exec_redirection_undo_list out for
@@ -6136,14 +6194,14 @@ fast_spawn_command (char *command, WORD_LIST *words,
 	  /* Redirection failed; do_redirections has already printed an
 	     error and recorded inverse ops for whatever it managed to
 	     apply.  Roll those back, restore the caller's undo lists,
-	     unblock signals, and fall back to the fork path so the
-	     child fails the same way under the existing machinery. */
+	     restore pipes/cloexec, unblock signals, and fall back to
+	     the fork path so the child fails the same way under the
+	     existing machinery. */
 	  cleanup_redirects (redirection_undo_list);
 	  dispose_redirects (exec_redirection_undo_list);
 	  redirection_undo_list = saved_undo_list;
 	  exec_redirection_undo_list = saved_exec_undo_list;
-	  sigprocmask (SIG_SETMASK, &oset, (sigset_t *)NULL);
-	  return (pid_t)-1;
+	  goto pipe_setup_fail;
 	}
 
       new_undo_list = redirection_undo_list;
@@ -6173,6 +6231,32 @@ fast_spawn_command (char *command, WORD_LIST *words,
       dispose_redirects (new_exec_undo_list);
     }
 
+  /* Restore FD_CLOEXEC on neighboring-pipe-stage fds. */
+  if (saved_cloexec)
+    {
+      for (i = 0; i < fds_to_close->size; i++)
+	if (saved_cloexec[i] >= 0)
+	  fcntl (i, F_SETFD, saved_cloexec[i]);
+      free (saved_cloexec);
+      saved_cloexec = NULL;
+    }
+
+  /* Restore fd 1, then fd 0.  Restoration order is the reverse of
+     setup order so that if pipe_in == 1 (fd 1 used as a pipe input)
+     the dup2 chain stays correct. */
+  if (saved_fd1 >= 0)
+    {
+      dup2 (saved_fd1, 1);
+      close (saved_fd1);
+      saved_fd1 = -1;
+    }
+  if (saved_fd0 >= 0)
+    {
+      dup2 (saved_fd0, 0);
+      close (saved_fd0);
+      saved_fd0 = -1;
+    }
+
   if (pid < 0)
     {
       /* spawnve failed; restore signals and fall back to fork+exec. */
@@ -6189,6 +6273,32 @@ fast_spawn_command (char *command, WORD_LIST *words,
   sigprocmask (SIG_SETMASK, &oset, (sigset_t *)NULL);
 
   return pid;
+
+pipe_setup_fail:
+  /* Restore everything we set up.  The order matches the cleanup path
+     above: restore CLOEXEC on neighboring fds, then restore fd 1,
+     then fd 0, then unblock signals.  saved_fd0/saved_fd1 may be -1
+     if the corresponding setup never ran or never finished; close()
+     and dup2() on -1 are skipped explicitly. */
+  if (saved_cloexec)
+    {
+      for (i = 0; i < fds_to_close->size; i++)
+	if (saved_cloexec[i] >= 0)
+	  fcntl (i, F_SETFD, saved_cloexec[i]);
+      free (saved_cloexec);
+    }
+  if (saved_fd1 >= 0)
+    {
+      dup2 (saved_fd1, 1);
+      close (saved_fd1);
+    }
+  if (saved_fd0 >= 0)
+    {
+      dup2 (saved_fd0, 0);
+      close (saved_fd0);
+    }
+  sigprocmask (SIG_SETMASK, &oset, (sigset_t *)NULL);
+  return (pid_t)-1;
 }
 #endif /* __CYGWIN__ */
 
